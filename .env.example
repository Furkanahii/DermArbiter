# ═══════════════════════════════════════════════════════════════
# DermArbiter — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values.
#   cp .env.example .env

# ───────────────────────────────────────────────────────────────
# Required
# ───────────────────────────────────────────────────────────────

# Google AI Studio API Key (for Gemini 2.5 Flash — Specialist & Moderator)
GOOGLE_API_KEY=your_google_api_key_here

# Hugging Face Token (for gated models: MedGemma, Qwen3-8B-Instruct)
HF_TOKEN=your_huggingface_token_here

# ───────────────────────────────────────────────────────────────
# Optional
# ───────────────────────────────────────────────────────────────

# Groq API key (optional — for accelerated inference)
GROQ_API_KEY=

# Override model cache directory (defaults to ~/.cache/huggingface)
HF_HOME=/path/to/cache

# ChromaDB persistence directory (defaults to ./chroma_db)
CHROMA_DB_PATH=./chroma_db

# Logging level override (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Random seed (overrides configs/default.yaml)
SEED=42
